package day6;

public class CustomerMain 
{
	public static void main(String[] args) 
	{
		Customer customer;
		try {
			customer = getCustomerByEmail("saqi@gmail.com");
		} catch (CustomerNotFoundException e) {
			// TODO Auto-generated catch block
			e.printStackTrace();
		}
		System.out.println(customer);
		
	}
	
	public static Customer getCustomerByEmail(String email) throws CustomerNotFoundException
	{
		
		return EkartDatabase.getAllCustomers().stream().filter(c->c.getCustEmail().equals(email)).findFirst().orElseThrow(()->new CustomerNotFoundException("cust not found with given email"));
		
	}

}
