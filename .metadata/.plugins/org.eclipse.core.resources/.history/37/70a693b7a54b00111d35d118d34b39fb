package day5;

@FunctionalInterface
interface Calc
{
	int square(int x);
}

public class LambdaDemo {
	public static void main(String[] args) 
	{
       Calc c = new Calc(){

    		@Override
    		public int square(int x) {

    			return x*x;
    		}
    	}
;
       System.out.println( c.square(100));

	}
}
