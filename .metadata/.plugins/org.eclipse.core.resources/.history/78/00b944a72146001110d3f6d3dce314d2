package day3;

class Parent
{
	public Object marry()
	{
	  System.out.println("Chandra Mukhi");
	return null;
	}	
}
class Child extends Parent
{
	@Override
	public String marry()
	{
	  System.out.println("Manjaulika");
	}	
	
}

public class MethodOverriding 
{
	public static void main(String[] args) 
	{
		new Child().marry();
	}

}
