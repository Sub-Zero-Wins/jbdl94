package day6;

import java.util.List;
import java.util.stream.Collectors;

public class CustomerMain 
{
	public static void main(String[] args) 
	{
		Customer customer =getCustomerByEmail("saqib@gmail.com");
		System.out.println(customer);
		
	}
	
	public static Customer getCustomerByEmail(String email)
	{
		EkartDatabase.getAllCustomers();
		
		return (Customer) EkartDatabase.getAllCustomers().stream().filter(mail->mail.equals(email)).collect(Collectors.toList());
		
	}

}
