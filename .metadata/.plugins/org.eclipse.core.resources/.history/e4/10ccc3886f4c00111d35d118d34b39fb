package day6;

public class CustomerMain 
{
	public static void main(String[] args) 
	{
		Customer customer =getCustomerByEmail("saqi@gmail.com");
		System.out.println(customer);
		
	}
	
	public static Customer getCustomerByEmail(String email)
	{
		
		return EkartDatabase.getAllCustomers().stream().filter(c->c.getCustEmail().equals(email)).findFirst().orElseThrow(()->new CustomerNotFoundException("cust not found with given email"));
		
	}

}
