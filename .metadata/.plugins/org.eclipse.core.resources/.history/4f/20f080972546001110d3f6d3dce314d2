package day3;

public class PlaneMain 
{
	public static void main(String[] args)
	{
		Plane p = new PassengerPlane(); //  upcasting parent ref pointing to child object. loose coupling
	
		airControl(p);
		
		//((PassengerPlane)(p)).carry();
		
		p = new CargoPlane();   
		airControl(p);
		
		//((CargoPlane)(p)).carry(); // downcasting to access specialized methods. down casting can only be done to upcasted objects
		
		
		
	}
	
	public static void airControl(Plane p)
	{
		p.fly();
		
	}

}
