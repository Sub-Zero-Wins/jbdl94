package day7;

class AutoSave extends Thread
{
	public void run()
	{
		for(;;)
		{
			try {
				Thread.sleep(2000);
			} catch (InterruptedException e) {
				// TODO Auto-generated catch block
				e.printStackTrace();
			}
			System.out.println("Auto saving...");
		}
	}
}


class AutoCorrect  extends Thread
{
	public void run()
	{
		for(;;)
		{
			try {
				Thread.sleep(2000);
			} catch (InterruptedException e) {
				// TODO Auto-generated catch block
				e.printStackTrace();
			}
			System.out.println("Auto correcting...");
		}
	}
}

class Type  extends Thread
{
	public void run()
	{
		for(int i=0;i<10;i++)
		{
			
			System.out.println("typing..."); 
			try {
				Thread.sleep(2000);
			} catch (InterruptedException e) {
				// TODO Auto-generated catch block
				e.printStackTrace();
			}
		}
	}
}

public class DaemonThreads 
{
	public static void main(String[] args) 
	{
		Type t1 = new Type();
		AutoCorrect t2= new AutoCorrect();
		AutoSave t3 = new AutoSave();
		
		t2.setDaemon(true);
		t3.setDaemon(true);
		
		t1.setPriority(10);
		t2.setPriority(1);
		t3.setPriority(1);
		
		t1.start();
		t2.start();
		t3.start();
		

		

	}

}
