package day5;

//@FunctionalInterface
interface Calc
{
	int square(int x);
	int cube(int x);
}

public class LambdaDemo {
	public static void main(String[] args) 
	{
       Calc c = new Calc(){

    		@Override
    		public int square(int x) {

    			return x*x;
    		}

			@Override
			public int cube(int x) {
				// TODO Auto-generated method stub
				return x*x*x;
			}
    	}
;
       System.out.println( c.square(100));

	}
}
